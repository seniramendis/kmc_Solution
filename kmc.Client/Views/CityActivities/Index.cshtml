@model IEnumerable<kmc.Client.Models.CityActivityViewModel>

@{
    ViewData["Title"] = "City Activities";
    var userRole = Context.Request.Cookies["UserRole"]; 
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bolder" style="color: var(--kandy-dark-teal);">Available City Activities</h2>
        @if (userRole == "Organizer")
        {
            <a asp-action="Create" class="btn btn-gold fw-bold px-4 rounded-pill shadow-sm">Create New Activity +</a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-4" role="alert">
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card hover-card shadow-sm border-0 mt-3 rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="background-color: var(--kandy-dark-teal); color: white;">
                    <tr>
                        <th class="p-4 border-0 rounded-top-start">Activity Name</th>
                        <th class="p-4 border-0">Category</th>
                        <th class="p-4 border-0">Date</th>
                        <th class="p-4 border-0">Venue</th>
                        <th class="p-4 border-0">Capacity</th>
                        
                        @if (userRole != null)
                        {
                            <th class="p-4 border-0 text-center rounded-top-end">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="p-4 fw-bold align-middle" style="color: var(--kandy-dark-teal);">@item.ActivityName</td>
                                <td class="p-4 align-middle"><span class="badge rounded-pill shadow-sm" style="background-color: var(--kandy-gold); color: white;">@item.Category</span></td>
                                <td class="p-4 align-middle text-muted fw-semibold">@item.ScheduledDate.ToString("MMM dd, yyyy h:mm tt")</td>
                                <td class="p-4 align-middle text-muted">@item.Venue</td>
                                <td class="p-4 align-middle text-center fw-bold text-muted">@item.MaxParticipants</td>
                                
                                @if (userRole == "Organizer")
                                {
                                    <td class="p-4 text-center align-middle">
                                        <a asp-action="Edit" asp-route-id="@item.ActivityId" class="btn btn-sm btn-outline-dark fw-bold rounded-pill px-3">Edit</a>
                                        <a asp-action="Attendees" asp-route-id="@item.ActivityId" class="btn btn-sm btn-gold text-white ms-1 fw-bold rounded-pill px-3 shadow-sm">Attendees</a>
                                        <a asp-action="Delete" asp-route-id="@item.ActivityId" class="btn btn-sm btn-outline-danger ms-1 fw-bold rounded-pill px-3">Delete</a>
                                    </td>
                                }
                                else if (userRole == "Resident")
                                {
                                    <td class="p-4 text-center align-middle">
                                        <a asp-action="Book" asp-route-id="@item.ActivityId" class="btn btn-sm btn-emerald fw-bold px-4 rounded-pill shadow-sm">Book Now</a>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center p-5 text-muted">
                                <h4 class="fw-light mt-3">No activities found.</h4>
                                <p>Check back later or register as an Organizer to create one!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>