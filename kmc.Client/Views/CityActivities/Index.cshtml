@model IEnumerable<kmc.Client.Models.CityActivityViewModel>

@{
    ViewData["Title"] = "City Activities";
    // Checks who is currently logged in!
    var userRole = Context.Request.Cookies["UserRole"]; 
}

<div class="container mt-4">
    <h2>Available City Activities</h2>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (userRole == "Organizer")
    {
        <div class="mb-3">
            <a asp-action="Create" class="btn btn-primary">Create New Activity +</a>
        </div>
    }

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Activity Name</th>
                <th>Category</th>
                <th>Date</th>
                <th>Venue</th>
                <th>Max Participants</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ActivityName</td>
                        <td><span class="badge bg-primary">@item.Category</span></td>
                        <td>@item.ScheduledDate.ToString("MMM dd, yyyy h:mm tt")</td>
                        <td>@item.Venue</td>
                        <td>@item.MaxParticipants</td>
                        <td>
                            @if (userRole == "Organizer")
                            {
                                <a asp-action="Edit" asp-route-id="@item.ActivityId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.ActivityId" class="btn btn-sm btn-danger ms-1">Delete</a>
                            }
                            else if (userRole == "Resident")
                            {
                                <a asp-action="Book" asp-route-id="@item.ActivityId" class="btn btn-sm btn-success">Book Now</a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
    
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-warning">
            No activities found.
        </div>
    }
</div>