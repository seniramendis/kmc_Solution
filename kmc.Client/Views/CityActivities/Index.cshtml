@model IEnumerable<kmc.Client.Models.CityActivityViewModel>

@{
    ViewData["Title"] = "City Activities";
    var userRole = Context.Request.Cookies["UserRole"]; 
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Available City Activities</h2>
        @if (userRole == "Organizer")
        {
            <a asp-action="Create" class="btn btn-primary fw-bold px-4 rounded-pill">Create New Activity +</a>
        }
    </div>
    <hr />

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <strong>Success!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mt-3">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="p-3">Activity Name</th>
                        <th class="p-3">Category</th>
                        <th class="p-3">Date</th>
                        <th class="p-3">Venue</th>
                        <th class="p-3">Capacity</th>
                        
                        @if (userRole != null)
                        {
                            <th class="p-3 text-center">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="p-3 fw-bold align-middle">@item.ActivityName</td>
                                <td class="p-3 align-middle"><span class="badge bg-primary">@item.Category</span></td>
                                <td class="p-3 align-middle">@item.ScheduledDate.ToString("MMM dd, yyyy h:mm tt")</td>
                                <td class="p-3 align-middle">@item.Venue</td>
                                <td class="p-3 align-middle text-center">@item.MaxParticipants</td>
                                
                                @if (userRole == "Organizer")
                                {
                                    <td class="p-3 text-center align-middle">
                                        <a asp-action="Edit" asp-route-id="@item.ActivityId" class="btn btn-sm btn-warning">Edit</a>
                                        <a asp-action="Attendees" asp-route-id="@item.ActivityId" class="btn btn-sm btn-info text-white ms-1 fw-bold">Attendees</a>
                                        <a asp-action="Delete" asp-route-id="@item.ActivityId" class="btn btn-sm btn-danger ms-1">Delete</a>
                                    </td>
                                }
                                else if (userRole == "Resident")
                                {
                                    <td class="p-3 text-center align-middle">
                                        <a asp-action="Book" asp-route-id="@item.ActivityId" class="btn btn-sm btn-success fw-bold px-3">Book Now</a>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center p-5 text-muted">
                                <h4>No activities found.</h4>
                                <p>Check back later or register as an Organizer to create one!</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>