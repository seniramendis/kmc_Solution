@model IEnumerable<kmc.Client.Models.EventBookingViewModel>

@{
    ViewData["Title"] = "Event Attendees";
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold">👥 Event Attendees</h2>
    <p class="text-muted">Here are all the residents who have booked tickets for this activity.</p>
    <hr />

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="p-3">Resident Name</th>
                        <th class="p-3">Contact Email</th>
                        <th class="p-3">Booking Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var attendee in Model)
                        {
                            <tr>
                                <td class="p-3 fw-bold">@attendee.ResidentName</td>
                                <td class="p-3">@attendee.ContactEmail</td>
                                <td class="p-3">@attendee.BookingDate.ToString("MMM dd, yyyy h:mm tt")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center p-5 text-muted">
                                <h4>No bookings yet!</h4>
                                <p>When residents book your event, they will appear here.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="mt-4">
        <a asp-action="Index" class="btn btn-secondary px-4 rounded-pill">← Back to Activities</a>
    </div>
</div>