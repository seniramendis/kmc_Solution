@model kmc.Client.Models.CityActivityViewModel

@{
    ViewData["Title"] = "Delete Activity";
}

<div class="container mt-4">
    <h2 class="text-danger">Delete City Activity</h2>
    <h3>Are you sure you want to delete this event?</h3>
    <hr />

    <div>
        <dl class="row mt-3">
            <dt class="col-sm-3">Activity Name</dt>
            <dd class="col-sm-9">@Model.ActivityName</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9"><span class="badge bg-primary">@Model.Category</span></dd>

            <dt class="col-sm-3">Scheduled Date</dt>
            <dd class="col-sm-9">@Model.ScheduledDate.ToString("MMM dd, yyyy h:mm tt")</dd>

            <dt class="col-sm-3">Venue</dt>
            <dd class="col-sm-9">@Model.Venue</dd>

            <dt class="col-sm-3">Max Participants</dt>
            <dd class="col-sm-9">@Model.MaxParticipants</dd>
            
            <dt class="col-sm-3">Organizer ID</dt>
            <dd class="col-sm-9">@Model.OrganizerId</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="ActivityId" />
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>