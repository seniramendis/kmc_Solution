@model IEnumerable<kmc.Client.Models.EventBookingViewModel>

@{
    ViewData["Title"] = "My Bookings";
}

<div class="container mt-4">
    <h2 class="text-success fw-bold">🎟️ My Event Tickets</h2>
    <p class="text-muted">Here are all the city activities you have successfully registered for.</p>
    <hr />

    <div class="row mt-4">
        @if (Model != null && Model.Any())
        {
            foreach (var booking in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm border-success h-100 rounded-3">
                        <div class="card-header bg-success text-white fw-bold">
                            @booking.CityActivity?.ActivityName
                        </div>
                        <div class="card-body">
                            <p class="mb-1"><strong>📍 Venue:</strong> @booking.CityActivity?.Venue</p>
                            <p class="mb-1"><strong>📅 Date:</strong> @booking.CityActivity?.ScheduledDate.ToString("MMM dd, yyyy h:mm tt")</p>
                            <p class="mb-1"><strong>🏷️ Category:</strong> <span class="badge bg-secondary">@booking.CityActivity?.Category</span></p>
                            <hr />
                            <p class="mb-0 text-muted small"><strong>Ticket Holder:</strong> @booking.ResidentName</p>
                            <p class="mb-0 text-muted small"><strong>Booked On:</strong> @booking.BookingDate.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center p-5 rounded-4 shadow-sm">
                    <h4>You haven't booked any events yet!</h4>
                    <p>Head over to the Activities page to discover what's happening in your city.</p>
                    <a asp-action="Index" class="btn btn-primary mt-3 px-4 rounded-pill">Explore Events</a>
                </div>
            </div>
        }
    </div>
</div>