@model IEnumerable<kmc.Client.Models.EventBookingViewModel>

@{
    ViewData["Title"] = "My Bookings";
}

<div class="container mt-5">
    <h2 class="fw-bolder" style="color: var(--kandy-emerald);">My Event Tickets</h2>
    <p class="text-muted">Here are all the city activities you have successfully registered for.</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show fw-bold shadow-sm rounded-3 mt-3" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show fw-bold shadow-sm rounded-3 mt-3" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mt-4 g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var booking in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card hover-card shadow-sm h-100 rounded-4 flex-column" style="border: 2px solid var(--kandy-emerald) !important;">
                        <div class="card-header border-0 p-4 text-center" style="background-color: var(--kandy-emerald); color: white;">
                            <h4 class="fw-bold mb-0">@booking.CityActivity?.ActivityName</h4>
                        </div>
                        <div class="card-body p-4 d-flex flex-column">
                            <p class="mb-2 text-muted"><strong style="color: var(--kandy-dark-teal);">Venue:</strong> @booking.CityActivity?.Venue</p>
                            <p class="mb-2 text-muted"><strong style="color: var(--kandy-dark-teal);">Date:</strong> @booking.CityActivity?.ScheduledDate.ToString("MMM dd, yyyy h:mm tt")</p>
                            <p class="mb-4"><strong style="color: var(--kandy-dark-teal);">Category:</strong> <span class="badge rounded-pill shadow-sm ms-2" style="background-color: var(--kandy-gold); color: white;">@booking.CityActivity?.Category</span></p>
                            
                            <div class="p-3 rounded-3 mb-3" style="background-color: #f8f9fa;">
                                <p class="mb-1 text-muted small"><strong>Ticket Holder:</strong> @booking.ResidentName</p>
                                <p class="mb-0 text-muted small"><strong>Booked On:</strong> @booking.BookingDate.ToString("MMM dd, yyyy")</p>
                            </div>

                            <div class="mt-auto pt-3 border-top border-light">
                                <form asp-action="CancelBooking" method="post">
                                    <input type="hidden" name="bookingId" value="@booking.BookingId" />
                                    <button type="submit" class="btn btn-outline-danger w-100 fw-bold rounded-pill shadow-sm" onclick="return confirm('Are you sure you want to cancel your ticket for @(booking.CityActivity?.ActivityName)? This cannot be undone.');">
                                        Cancel Ticket
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm rounded-4 text-center p-5 mt-4" style="background-color: #f8f9fa;">
                    <h4 class="fw-bold" style="color: var(--kandy-dark-teal);">You haven't booked any events yet!</h4>
                    <p class="text-muted mb-4">Head over to the Activities page to discover what's happening in your city.</p>
                    <a asp-action="Index" class="btn btn-emerald btn-lg px-5 rounded-pill fw-bold shadow-sm text-white">Explore Events</a>
                </div>
            </div>
        }
    </div>
</div>