@{
    ViewData["Title"] = "Home Page";
    // We check the role so we can show smart buttons!
    var userRole = Context.Request.Cookies["UserRole"];
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-3 fw-bold text-primary">Welcome to the KMC Portal</h1>
        <p class="lead text-muted mt-3">The official platform for managing and discovering city events.</p>
    </div>

    <div class="row text-center mt-5">
        <div class="col-md-6 mb-4">
            <div class="card shadow border-0 h-100 rounded-4">
                <div class="card-body p-5 bg-light rounded-4">
                    <h2 class="fw-bold text-success">🏙️ City Residents</h2>
                    <p class="mt-3 text-secondary">Discover exciting local events, sports, and workshops. Find what you love and book your spot instantly.</p>
                    <a asp-controller="CityActivities" asp-action="Index" class="btn btn-success btn-lg mt-4 px-5 rounded-pill">Explore Events</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow border-0 h-100 rounded-4">
                <div class="card-body p-5 bg-light rounded-4">
                    <h2 class="fw-bold text-primary">📅 Event Organizers</h2>
                    <p class="mt-3 text-secondary">Plan, publish, and manage your city activities. Reach thousands of residents and track your bookings in real-time.</p>
                    
                    @if(userRole == "Organizer")
                    {
                        <a asp-controller="CityActivities" asp-action="Create" class="btn btn-primary btn-lg mt-4 px-5 rounded-pill">Create an Event</a>
                    }
                    else if(userRole == "Resident")
                    {
                        <a asp-controller="CityActivities" asp-action="Index" class="btn btn-outline-primary btn-lg mt-4 px-5 rounded-pill">View Schedule</a>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-outline-primary btn-lg mt-4 px-5 rounded-pill">Join as Organizer</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>