@model kmc.Client.Models.LoginViewModel
@{ ViewData["Title"] = "Log In"; }

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success fw-bold rounded-3 shadow-sm">@TempData["SuccessMessage"]</div>
            }

            <div class="card shadow-lg border-0 rounded-4 hover-card">
                <div class="card-header text-white text-center p-4 border-0 rounded-top-4" style="background-color: var(--kandy-dark-teal);">
                    <h3 class="mb-0 fw-bolder">Welcome Back</h3>
                </div>
                
                <div class="card-body p-5 bg-white">
                    <form asp-action="Login">
                        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold text-center"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold text-muted">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg bg-light border-0 rounded-3" placeholder="name@example.com" required />
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold text-muted">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg bg-light border-0 rounded-3" placeholder="Enter your password" required />
                        </div>
                        
                        <button type="submit" class="btn btn-emerald btn-lg w-100 fw-bold rounded-pill shadow-sm mt-3">Log In</button>
                    </form>
                    
                    <div class="text-center mt-4">
                        <p class="text-muted small mb-0">Don't have an account?</p>
                        <a asp-action="Register" class="fw-bold text-decoration-none fs-6" style="color: var(--kandy-gold);">Register here</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}