@model kmc.Client.Models.LoginViewModel
@{ ViewData["Title"] = "Log In"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Welcome Back</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Login">
                        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg" required />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100">Log In</button>
                    </form>
                    <div class="text-center mt-3">
                        <p>Don't have an account? <a asp-action="Register">Register here</a>.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>