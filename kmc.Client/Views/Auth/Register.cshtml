@model kmc.Client.Models.RegisterViewModel
@{ ViewData["Title"] = "Register"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white text-center">
                    <h3 class="mb-0">Create an Account</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register">
                        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg" required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-bold">Password</label>
                            <input asp-for="Password" class="form-control form-control-lg" required />
                            <small class="text-muted">Must have 1 uppercase, 1 number, and 1 special character.</small>
                        </div>
                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">Confirm Password</label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg" required />
                        </div>
                        <button type="submit" class="btn btn-success btn-lg w-100">Register</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>